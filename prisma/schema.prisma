datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User model for role-based authentication (ADMIN, EMPLOYER, CANDIDATE)
model User {
  id           String           @id @default(uuid())
  email        String           @unique
  passwordHash String
  role         String           // "ADMIN", "EMPLOYER", "CANDIDATE"
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  candidate    CandidateProfile?
  employer     EmployerProfile?
}

// Profile for Candidate users
model CandidateProfile {
  id              String        @id @default(uuid())
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName        String
  phone           String?
  passportNumber  String?
  resumeUrl       String?
  currentSalary   String?
  expectedSalary  String?
  skills          String?       // Comma separated skills
  experienceYears Int?
  education       String?
  location        String?
  status          String        @default("ACTIVE") // "ACTIVE", "PLACED", "INACTIVE"
  applications    Application[]
}

// Profile for Employer users
model EmployerProfile {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  industry      String?
  website       String?
  contactPerson String?
  phone         String?
  address       String?
  isVerified    Boolean  @default(false)
  jobs          Job[]
}

// Job listing model
model Job {
  id           String        @id @default(uuid())
  title        String
  description  String
  requirements String
  benefits     String?
  sector       String        // e.g., "Healthcare", "Construction", "Oil & Gas", "Hospitality", "Logistics", "Manufacturing"
  country      String        // e.g., "Saudi Arabia", "UAE", "Qatar", "Oman", "Kuwait", "Germany", "Singapore"
  salaryRange  String?
  vacancies    Int           @default(1)
  status       String        @default("OPEN") // "OPEN", "CLOSED"
  employerId   String
  employer     EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

// Application linking Candidates and Jobs
model Application {
  id              String   @id @default(uuid())
  jobId           String
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId     String
  candidate       CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  status          String   @default("APPLIED") 
  // Stages: "APPLIED", "SHORTLISTED", "INTERVIEW_SCHEDULED", "SELECTED", "VISA_STAGE", "MOBILIZED", "REJECTED"
  
  visaStatus      String   @default("NOT_STARTED")
  // Visa Stages: "NOT_STARTED", "DOCUMENT_VERIFICATION", "EMBASSY_SUBMISSION", "VISA_STAMPED", "FLIGHT_BOOKED", "DEPLOYED"
  
  notes           String?  // Recruiter notes/comments
  interviewDate   DateTime?
  interviewLink   DateTime? // Optional interview info
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

// Contact form inquiries (CRM Leads)
model Inquiry {
  id          String   @id @default(uuid())
  name        String
  email       String
  companyName String?
  phone       String?
  message     String
  status      String   @default("PENDING") // "PENDING", "CONTACTED", "ARCHIVED"
  createdAt   DateTime @default(now())
}

// Blog CMS articles
model BlogPost {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  summary   String
  content   String
  category  String   // e.g., "Visa Update", "Industry Insights", "Hiring Tips"
  author    String   @default("Deepak Chauhan")
  status    String   @default("PUBLISHED") // "DRAFT", "PUBLISHED"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Gallery items
model GalleryItem {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String
  category    String   // e.g., "Trade Test", "Departure", "Office", "Event"
  createdAt   DateTime @default(now())
}
